{
  "name": "bangumibar",
  "version": "1.0.0",
  "description": "Bangumi 追番管理菜单栏应用",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite build && electron .",
    "build": "vite build",
    "build:app": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "esbuild": "^0.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "has-tostringtag": "^1.0.2",
    "jimp": "^1.6.1",
    "pngjs": "^7.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.bangumibar.app",
    "productName": "BangumiBar",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
